APP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=10s
APP_ENV=development

AI_PROVIDER=mock
AI_MOCK_LATENCY=200ms
AI_HTTP_TIMEOUT=20s
AI_FALLBACK_TO_MOCK=true
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-1.5-flash
AI_CLAUDE_API_KEY=
AI_CLAUDE_MODEL=claude-3-5-sonnet-20241022

SQLITE_PATH=./data/self-study.db
UPLOAD_MAX_BYTES=20971520

LOG_LEVEL=info
LOG_FORMAT=json
LOG_STDOUT_ENABLED=true
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./data/logs/app.log
LOG_FILE_MAX_SIZE_MB=20
LOG_FILE_MAX_BACKUPS=10
LOG_FILE_MAX_AGE_DAYS=7
LOG_COMPRESS=false
LOG_HTTP_BODY_ENABLED=false
LOG_HTTP_BODY_MAX_BYTES=2048
LOG_REDACTION_MODE=production_only
LOG_SQL_ENABLED=true
LOG_SQL_SLOW_MS=200
LOG_AI_SUMMARY_ENABLED=true
